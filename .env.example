# MongoDB Configuration
# For local development (without Docker):
MONGO_URI=mongodb://localhost:27017/chatapp

# For Docker Compose (update with your credentials):
# MONGO_URI=mongodb://YOUR_USERNAME:YOUR_PASSWORD@mongo:27017/chatapp?authSource=admin

# MongoDB Credentials (REQUIRED for Docker Compose)
# IMPORTANT: Change these to secure values!
MONGO_USERNAME=your_mongo_username
MONGO_PASSWORD=your_secure_mongo_password

# Backend Configuration
PORT=8000
NODE_ENV=development

# JWT Secret (REQUIRED - use a strong random string)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Cloudinary Configuration (REQUIRED)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Docker Registry (optional - for CI/CD)
DOCKER_REGISTRY=
IMAGE_TAG=latest
